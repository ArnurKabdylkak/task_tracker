# Токен бота от @BotFather (обязательно).
BOT_TOKEN=

# Telegram ID начальников через запятую (например: 123456789,987654321).
# Узнать свой ID можно командой /id у бота.
BOSS_IDS=

# Таймзона (по умолчанию Europe/Moscow).
BOT_TZ=Europe/Moscow

# Время утреннего напоминания HH:MM (по умолчанию 10:00).
REMINDER_TIME=10:00

# Время повторного напоминания не отписавшимся HH:MM (по умолчанию 14:00).
FOLLOWUP_TIME=14:00

# Путь к файлу БД. В Docker переопределён на /data/tasks.db (volume),
# локально по умолчанию tasks.db в рабочем каталоге.
# DB_PATH=tasks.db
