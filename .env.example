# Токен бота от @BotFather (обязательно). НЕ вписывайте сюда реальный токен —
# этот файл коммитится. Реальные значения держите в .env (он в .gitignore).
BOT_TOKEN=

# Начальники через запятую. Можно указывать числовые Telegram ID и/или @username,
# вперемешку — например: 123456789,@ivan,olga
#   ID  — надёжнее: не меняется. Узнать свой можно командой /id у бота.
#   ник — удобный псевдоним, но при смене username права слетят, а у кого-то
#         ника может не быть вовсе.
BOSS_IDS=

# Таймзона (по умолчанию Asia/Almaty — время Астаны, UTC+5).
BOT_TZ=Asia/Almaty

# Время утреннего напоминания HH:MM (по умолчанию 10:00).
REMINDER_TIME=10:00

# Время повторного напоминания не отписавшимся HH:MM (по умолчанию 14:00).
FOLLOWUP_TIME=14:00

# Путь к файлу БД. В Docker переопределён на /data/tasks.db (volume),
# локально по умолчанию tasks.db в рабочем каталоге.
# DB_PATH=tasks.db
